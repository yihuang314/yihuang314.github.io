{"title":"论文","markdown":{"yaml":{"title":"论文","lang":"zh","bibliography":"references.bib","csl":"ieee_tcasi.csl","citeproc":true,"nocite":"@*\n"},"containsRefs":true,"markdown":"\n\n<div class=\"pub-controls\" aria-label=\"论文筛选控件\">\n  <input id=\"pub-search\" type=\"search\" placeholder=\"搜索论文...\" aria-label=\"搜索论文\">\n  <select id=\"pub-type\" aria-label=\"按类型筛选\">\n    <option value=\"all\">全部类型</option>\n    <option value=\"journal\">期刊</option>\n    <option value=\"conference\">会议</option>\n  </select>\n  <select id=\"pub-year-filter\" aria-label=\"按年份筛选\">\n    <option value=\"all\">全部年份</option>\n  </select>\n</div>\n\n::: {#refs}\n:::\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n  const refs = document.querySelector(\"#refs\");\n  if (!refs) return;\n\n  const nameRegex = /\\b(Yi Huang|Y\\.?\\s*Huang|Huang,\\s*Yi|Huang,\\s*Y\\.?)\\b/g;\n  async function ensureEntries() {\n    let rawEntries = Array.from(refs.querySelectorAll(\".csl-entry\"));\n    if (rawEntries.length) return rawEntries;\n\n    try {\n      const html = await fetch(\"publications.html\").then((r) => r.text());\n      const doc = new DOMParser().parseFromString(html, \"text/html\");\n      const sourceRefs = doc.querySelector(\"#refs\");\n      if (sourceRefs) {\n        refs.innerHTML = sourceRefs.innerHTML;\n      }\n    } catch (_) {\n      // If fetch fails, keep empty.\n    }\n\n    return Array.from(refs.querySelectorAll(\".csl-entry\"));\n  }\n\n  ensureEntries().then((rawEntries) => {\n    const entries = rawEntries.map((entry, index) => {\n      const rightInline = entry.querySelector(\".csl-right-inline\");\n      const authorNode = Array.from(rightInline?.childNodes || []).find(\n        (node) => node.nodeType === Node.TEXT_NODE && (node.textContent || \"\").trim()\n      );\n      entry.innerHTML = entry.innerHTML.replace(nameRegex, \"<strong>$1</strong>\");\n      entry.querySelectorAll(\"i, em\").forEach((el) => {\n        if (el.closest(\"strong\")) return;\n        const strong = document.createElement(\"strong\");\n        el.parentNode.insertBefore(strong, el);\n        strong.appendChild(el);\n      });\n      const text = entry.textContent || \"\";\n      const yearMatches = text.match(/\\b(19|20)\\d{2}\\b/g) || [];\n      const year = yearMatches.length ? Number(yearMatches[yearMatches.length - 1]) : null;\n      const type = /proceedings|conference|symposium|workshop|proc\\.?/i.test(text)\n        ? \"conference\"\n        : \"journal\";\n      return { entry, text: text.toLowerCase(), year, type, index };\n    });\n\n    const searchInput = document.querySelector(\"#pub-search\");\n    const typeSelect = document.querySelector(\"#pub-type\");\n    const yearFilter = document.querySelector(\"#pub-year-filter\");\n\n    const years = Array.from(\n      new Set(entries.map((item) => item.year).filter((year) => year !== null))\n    ).sort((a, b) => b - a);\n\n    if (yearFilter) {\n      for (const year of years) {\n        const option = document.createElement(\"option\");\n        option.value = String(year);\n        option.textContent = String(year);\n        yearFilter.appendChild(option);\n      }\n    }\n\n    function scrollToHashTarget() {\n      const hash = window.location.hash ? decodeURIComponent(window.location.hash.slice(1)) : \"\";\n      if (!hash) return;\n      const target = document.getElementById(hash);\n      if (!target) return;\n      target.scrollIntoView({ block: \"start\" });\n    }\n\n    function render() {\n      const query = (searchInput?.value || \"\").trim().toLowerCase();\n      const type = typeSelect?.value || \"all\";\n      const yearValue = yearFilter?.value || \"all\";\n      let filtered = entries.filter((item) => {\n        const matchesQuery = !query || item.text.includes(query);\n        const matchesType = type === \"all\" || item.type === type;\n        const matchesYear = yearValue === \"all\" || String(item.year) === yearValue;\n        return matchesQuery && matchesType && matchesYear;\n      });\n\n      filtered.sort((a, b) => a.index - b.index);\n\n      refs.innerHTML = \"\";\n      for (const item of filtered) {\n        refs.appendChild(item.entry);\n      }\n\n      requestAnimationFrame(() => {\n        requestAnimationFrame(scrollToHashTarget);\n      });\n    }\n\n    searchInput?.addEventListener(\"input\", render);\n    typeSelect?.addEventListener(\"change\", render);\n    yearFilter?.addEventListener(\"change\", render);\n    window.addEventListener(\"hashchange\", scrollToHashTarget);\n    render();\n  });\n});\n</script>\n","srcMarkdownNoYaml":"\n\n<div class=\"pub-controls\" aria-label=\"论文筛选控件\">\n  <input id=\"pub-search\" type=\"search\" placeholder=\"搜索论文...\" aria-label=\"搜索论文\">\n  <select id=\"pub-type\" aria-label=\"按类型筛选\">\n    <option value=\"all\">全部类型</option>\n    <option value=\"journal\">期刊</option>\n    <option value=\"conference\">会议</option>\n  </select>\n  <select id=\"pub-year-filter\" aria-label=\"按年份筛选\">\n    <option value=\"all\">全部年份</option>\n  </select>\n</div>\n\n::: {#refs}\n:::\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n  const refs = document.querySelector(\"#refs\");\n  if (!refs) return;\n\n  const nameRegex = /\\b(Yi Huang|Y\\.?\\s*Huang|Huang,\\s*Yi|Huang,\\s*Y\\.?)\\b/g;\n  async function ensureEntries() {\n    let rawEntries = Array.from(refs.querySelectorAll(\".csl-entry\"));\n    if (rawEntries.length) return rawEntries;\n\n    try {\n      const html = await fetch(\"publications.html\").then((r) => r.text());\n      const doc = new DOMParser().parseFromString(html, \"text/html\");\n      const sourceRefs = doc.querySelector(\"#refs\");\n      if (sourceRefs) {\n        refs.innerHTML = sourceRefs.innerHTML;\n      }\n    } catch (_) {\n      // If fetch fails, keep empty.\n    }\n\n    return Array.from(refs.querySelectorAll(\".csl-entry\"));\n  }\n\n  ensureEntries().then((rawEntries) => {\n    const entries = rawEntries.map((entry, index) => {\n      const rightInline = entry.querySelector(\".csl-right-inline\");\n      const authorNode = Array.from(rightInline?.childNodes || []).find(\n        (node) => node.nodeType === Node.TEXT_NODE && (node.textContent || \"\").trim()\n      );\n      entry.innerHTML = entry.innerHTML.replace(nameRegex, \"<strong>$1</strong>\");\n      entry.querySelectorAll(\"i, em\").forEach((el) => {\n        if (el.closest(\"strong\")) return;\n        const strong = document.createElement(\"strong\");\n        el.parentNode.insertBefore(strong, el);\n        strong.appendChild(el);\n      });\n      const text = entry.textContent || \"\";\n      const yearMatches = text.match(/\\b(19|20)\\d{2}\\b/g) || [];\n      const year = yearMatches.length ? Number(yearMatches[yearMatches.length - 1]) : null;\n      const type = /proceedings|conference|symposium|workshop|proc\\.?/i.test(text)\n        ? \"conference\"\n        : \"journal\";\n      return { entry, text: text.toLowerCase(), year, type, index };\n    });\n\n    const searchInput = document.querySelector(\"#pub-search\");\n    const typeSelect = document.querySelector(\"#pub-type\");\n    const yearFilter = document.querySelector(\"#pub-year-filter\");\n\n    const years = Array.from(\n      new Set(entries.map((item) => item.year).filter((year) => year !== null))\n    ).sort((a, b) => b - a);\n\n    if (yearFilter) {\n      for (const year of years) {\n        const option = document.createElement(\"option\");\n        option.value = String(year);\n        option.textContent = String(year);\n        yearFilter.appendChild(option);\n      }\n    }\n\n    function scrollToHashTarget() {\n      const hash = window.location.hash ? decodeURIComponent(window.location.hash.slice(1)) : \"\";\n      if (!hash) return;\n      const target = document.getElementById(hash);\n      if (!target) return;\n      target.scrollIntoView({ block: \"start\" });\n    }\n\n    function render() {\n      const query = (searchInput?.value || \"\").trim().toLowerCase();\n      const type = typeSelect?.value || \"all\";\n      const yearValue = yearFilter?.value || \"all\";\n      let filtered = entries.filter((item) => {\n        const matchesQuery = !query || item.text.includes(query);\n        const matchesType = type === \"all\" || item.type === type;\n        const matchesYear = yearValue === \"all\" || String(item.year) === yearValue;\n        return matchesQuery && matchesType && matchesYear;\n      });\n\n      filtered.sort((a, b) => a.index - b.index);\n\n      refs.innerHTML = \"\";\n      for (const item of filtered) {\n        refs.appendChild(item.entry);\n      }\n\n      requestAnimationFrame(() => {\n        requestAnimationFrame(scrollToHashTarget);\n      });\n    }\n\n    searchInput?.addEventListener(\"input\", render);\n    typeSelect?.addEventListener(\"change\", render);\n    yearFilter?.addEventListener(\"change\", render);\n    window.addEventListener(\"hashchange\", scrollToHashTarget);\n    render();\n  });\n});\n</script>\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":"auto","echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"markdown"},"render":{"keep-tex":false,"keep-typ":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"default","fig-pos":null,"fig-env":null,"code-fold":"none","code-overflow":"scroll","code-link":false,"code-line-numbers":false,"code-tools":false,"tbl-colwidths":"auto","merge-includes":true,"inline-includes":false,"preserve-yaml":false,"latex-auto-mk":true,"latex-auto-install":true,"latex-